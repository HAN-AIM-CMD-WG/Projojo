# ============================================================================
# Deterministic local E2E test stack environment
# ============================================================================

ENVIRONMENT=development

# ============================================================================
# Host-exposed test ports (1012x range)
# ============================================================================
FRONTEND_PORT=10121
BACKEND_PORT=10122
TYPEDB_PORT=10123
TYPEDB_STUDIO_PORT=10124
MAILHOG_SMTP_HOST_PORT=10125
MAILHOG_WEB_PORT=10126

# ============================================================================
# Backend / TypeDB configuration
# ============================================================================
TYPEDB_NAME=projojo_db
TYPEDB_HOST_NAME=typedb
TYPEDB_SERVER_ADDR=${TYPEDB_HOST_NAME}:1729
TYPEDB_EDITION=Core
TYPEDB_USERNAME=admin
TYPEDB_DEFAULT_PASSWORD=password
TYPEDB_NEW_PASSWORD=password

# Uncomment to reset the database automatically on backend startup
# RESET_DB=yes

# ============================================================================
# Frontend configuration
# ============================================================================
VITE_APP_NAME="Projojo - student assignment portal"
VITE_APP_VERSION=0.7.0-e2e
VITE_BACKEND_HOST=
VITE_BACKEND_PORT=${BACKEND_PORT}
FRONTEND_URL=http://localhost:${FRONTEND_PORT}

# ============================================================================
# Mail / local test services
# ============================================================================
EMAIL_DEFAULT_SENDER=noreply@test.projojo.local
EMAIL_SMTP_HOST=mailhog
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=

# ============================================================================
# Test-only secrets and dummy OAuth credentials
# These values are intentionally non-production and exist only so the local
# test stack can boot without depending on developer-specific secrets.
# ============================================================================
SESSIONS_SECRET_KEY=projojo-e2e-session-secret-key
JWT_SECRET_KEY=projojo-e2e-jwt-secret-key
GOOGLE_CLIENT_ID=projojo-e2e-google-client-id
GOOGLE_CLIENT_SECRET=projojo-e2e-google-client-secret
GITHUB_CLIENT_ID=projojo-e2e-github-client-id
GITHUB_CLIENT_SECRET=projojo-e2e-github-client-secret
MICROSOFT_CLIENT_ID=projojo-e2e-microsoft-client-id
MICROSOFT_CLIENT_SECRET=projojo-e2e-microsoft-client-secret
