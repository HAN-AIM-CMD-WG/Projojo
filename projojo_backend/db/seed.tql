    # --- HAN projecten ---
    $p_hanPres_move isa project,
        has id "cc010001-1111-4111-8111-000000010001",
        has name "Move je Buurt - HAN Lab Presikhaaf",
        has description "In samenwerking met Stichting Move en een Presikhaafse basisschool werken HAN-studenten aan kansengelijkheid: kinderen en studenten leren elkaars leefwereld kennen en bedenken samen hoe zij hun buurt kunnen verbeteren. De projectgroep begeleidt de kinderen, faciliteert werkvormen en rapporteert over bereik en impact.",
        has imagePath "default.png",
        has location "Presikhaaf, Arnhem",
        has createdAt 2024-09-01T09:00:00+0000,
        has startDate 2024-09-15T00:00:00+0000,
        has endDate 2025-06-30T23:59:00+0000,
        has isPublic true;

    $p_hanPres_food isa project,
        has id "cc010002-1111-4111-8111-000000010002",
        has name "Food for Thoughts 2.0 - HAN Lab Presikhaaf",
        has description "Versterk de sociale band in Presikhaaf door ontmoetingen rond eten te laten terugkeren. Bouw voort op eerdere burendagen en gezamenlijke maaltijden: organiseer terugkerende bewonersdiners, werk samen met wijkpartners en meet het effect op sociale verbinding.",
        has imagePath "default.png",
        has location "Presikhaaf, Arnhem",
        has createdAt 2024-09-01T09:10:00+0000,
        has startDate 2024-09-15T00:00:00+0000,
        has endDate 2025-06-30T23:59:00+0000,
        has isPublic true;

    $p_hanMalb_vitaal isa project,
        has id "cc010003-1111-4111-8111-000000010003",
        has name "Vitaal Ouder Worden - HAN Lab Malburgen",
        has description "In het Huis voor de Wijk werken studenten aan een van de speerpunten van Malburgen: vitaal ouder worden. Organiseer tweewekelijkse wandel- en ontmoetactiviteiten (route, tijd, werving, draaiboek), inventariseer het bestaande aanbod bij Sportbedrijf Arnhem en breng uit wat het Huis voor de Wijk nog kan toevoegen.",
        has imagePath "default.png",
        has location "Malburgen-Oost, Arnhem",
        has createdAt 2025-01-15T09:00:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    $p_hanMalb_peiling isa project,
        has id "cc010004-1111-4111-8111-000000010004",
        has name "Wijkpeiling Malburgen - HAN Lab Malburgen",
        has description "Herhaal voor Malburgen de 'spijkerpeil'-wijkpeiling uit het Spijkerkwartier. Gebruik de leefplekmeter van Pharos om leefbaarheid, veiligheid, voorzieningen en participatie in kaart te brengen. Bouw voort op de themas die eerdere studenten al hebben geinventariseerd.",
        has imagePath "default.png",
        has location "Malburgen, Arnhem",
        has createdAt 2025-01-15T09:15:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    $p_hanNoord_finedu isa project,
        has id "cc010005-1111-4111-8111-000000010005",
        has name "Financiele Educatie Geitenkamp - HAN/Rijn IJssel Lab Arnhem-Noord",
        has description "Leer kinderen tot 12 jaar omgaan met (digitaal) geld. Studenten Sociaal Werk van Rijn IJssel en HAN ontwikkelen, na bronnenonderzoek en gesprekken met groep 7/8 van basisschool De Witte Vlinder, interactieve voorlichtingen en extra materiaal (spaarkaart) om mee te nemen naar huis.",
        has imagePath "default.png",
        has location "Geitenkamp, Arnhem",
        has createdAt 2024-09-01T09:25:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    $p_hanSpijker_zakgeld isa project,
        has id "cc010006-1111-4111-8111-000000010006",
        has name "Zakgeldproject - HAN Lectoraat Sociale Kwaliteit",
        has description "In gezinnen waar de financien krap zijn is zakgeld niet vanzelfsprekend. Onderzoekers werken samen met ervaringsdeskundigen en gezinnen uit Klarendal aan manieren om kinderen te ondersteunen bij hun financiele zelfstandigheid.",
        has imagePath "default.png",
        has location "Klarendal, Arnhem",
        has createdAt 2025-02-01T09:00:00+0000,
        has startDate 2025-02-15T00:00:00+0000,
        has endDate 2025-12-19T23:59:00+0000,
        has isPublic true;

    $p_hanDT isa project,
        has id "cc010007-1111-4111-8111-000000010007",
        has name "Digital Twinning Arnhem - HAN Academie IT & Mediadesign",
        has description "Samenwerking tussen HAN-studenten, docenten en onderzoekers van de Academie IT & Mediadesign met de gemeente Arnhem rond drie themas: informatie-gestuurd werken (beleid meten en bijsturen), 3D/Mixed Reality visualisaties van de openbare ruimte (voor inspraak en besluitvorming) en inclusieve digitale dienstverlening.",
        has imagePath "default.png",
        has location "Arnhem",
        has createdAt 2025-01-20T09:00:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-12-19T23:59:00+0000,
        has isPublic true;

    $p_hanOLA isa project,
        has id "cc010008-1111-4111-8111-000000010008",
        has name "OndernemersLab Arnhem (OLA)",
        has description "Studenten van HAN en Rijn IJssel werken samen met bedrijven in de Arnhemse binnenstad aan gezamenlijke projecten. Partners: Startclub Arnhem, gemeente Arnhem, Rijn IJssel. Doel: de ondernemersagenda van de binnenstad voeden met studentenenergie en de student-ondernemer-match versterken.",
        has imagePath "default.png",
        has location "Arnhem, Binnenstad",
        has createdAt 2025-01-20T09:30:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    # --- HVHL projecten ---
    $p_hvhl_industrie isa project,
        has id "cc020001-1111-4111-8111-000000020001",
        has name "Vergroening Industriestraat Arnhem",
        has description "Bedrijfspanden aan de Industriestraat (o.a. transportbedrijf, smederij) zijn toe aan vergroening. HVHL-studenten ontwerpen maatregelen voor de versteende straat, parkeerterreinen, gevels en daken. De ondernemers faciliteren en hebben budget beschikbaar gesteld.",
        has imagePath "default.png",
        has location "Industriestraat, Arnhem",
        has createdAt 2025-01-10T09:00:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    $p_hvhl_gpoort isa project,
        has id "cc020002-1111-4111-8111-000000020002",
        has name "Kantorenpark Gelderse Poort - Klimaatadaptatie",
        has description "In het kantorenpark nabij de N325 zijn meer dan 100 ondernemingen gevestigd met ca. 6.000 werknemers. Studenten onderzoeken welke aanpassingen (vergroening, waterberging, verkoeling) nodig zijn om het terrein toekomstbestendig te maken naast de al lopende verduurzaming van de gebouwen.",
        has imagePath "default.png",
        has location "Gelderse Poort, Arnhem",
        has createdAt 2025-01-10T09:15:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    $p_hvhl_dgg isa project,
        has id "cc020003-1111-4111-8111-000000020003",
        has name "DrieGasthuizen Rosendaalseweg - Hittestress",
        has description "Op de Rosendaalseweg (zelfstandige woningen en zorghuisvesting) spelen klimaatproblemen zoals hittestress. HAN-studenten leveren de stakeholderanalyse, HVHL-studenten de ruimtelijke analyse. Samen komen ze tot een plan dat toegankelijkheid, aantrekkelijke plekken en verkoeling van het gebouw verbetert.",
        has imagePath "default.png",
        has location "Rosendaalseweg, Arnhem",
        has createdAt 2025-01-10T09:30:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    $p_hvhl_voedselbos isa project,
        has id "cc020004-1111-4111-8111-000000020004",
        has name "Voedselbos-in-oprichting Elderveld",
        has description "Natuurcentrum Arnhem ontwikkelt in Elderveld, samen met het Kinderwijkteam Malburgen, een voedselbos met schoolmoestuintjes. De opgave: basisscholen en het AZC aan het project verbinden, gezonde voeding koppelen aan het raadsbesluit dat iedere leerling uit groep 6 een moestuintje krijgt.",
        has imagePath "default.png",
        has location "Elderveld, Arnhem",
        has createdAt 2025-01-10T09:45:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-10-31T23:59:00+0000,
        has isPublic true;

    $p_hvhl_kronenburg isa project,
        has id "cc020005-1111-4111-8111-000000020005",
        has name "Parkeerterrein van de Toekomst - Winkelcentrum Kronenburg",
        has description "Studenten ontwikkelden een verduurzamingsvoorstel voor het grote parkeerterrein van Kronenburg. Een overkapping die deels groen is, deels energie opwekt en schaduw op de bestrating brengt. Ruimte voor vergroening en waterberging als meerlaagse oplossing voor klimaatadaptatie.",
        has imagePath "default.png",
        has location "Kronenburg, Arnhem",
        has createdAt 2025-01-10T10:00:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    $p_hvhl_rijker isa project,
        has id "cc020006-1111-4111-8111-000000020006",
        has name "Bomen in Rijkerswoerd - Oorzakenonderzoek",
        has description "De bomen in Rijkerswoerd groeien niet goed. Oorzaken zijn onduidelijk (ruimtegebrek, klei-ondergrond?). HVHL-studenten doen bodem- en groeiplaatsonderzoek en leveren aanbevelingen voor beheer en herplant.",
        has imagePath "default.png",
        has location "Rijkerswoerd, Arnhem",
        has createdAt 2025-01-10T10:15:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    $p_hvhl_zwane isa project,
        has id "cc020007-1111-4111-8111-000000020007",
        has name "Zwanebloemlaan Malburgen - Binnenpleintjes Vergroenen",
        has description "Volkshuisvesting heeft aan de Zwanebloemlaan versteende en afgesloten binnenpleintjes. Een pleintje is al vergroend, voor de andere worden tegelwippen en verbetering van het binnenklimaat ingezet. Studenten Bouwkunde (sociale woningbouw) werken samen met Kinderwijkteam en stadstuinier aan hittebestendige ontwerpen.",
        has imagePath "default.png",
        has location "Zwanebloemlaan, Malburgen, Arnhem",
        has createdAt 2025-01-10T10:30:00+0000,
        has startDate 2025-02-03T00:00:00+0000,
        has endDate 2025-07-11T23:59:00+0000,
        has isPublic true;

    # --- ArtEZ projecten ---
    $p_artez_moving isa project,
        has id "cc030001-1111-4111-8111-000000030001",
        has name "MOVING (HI)STORIES - 't Arnhemse Broek",
        has description "Interdisciplinair project in 't Arnhemse Broek onder het motto 'Think Global, Act Local'. Tweedejaars bachelorstudenten van de docentenopleidingen in Arnhem werken in tien tot veertien collectieven vanuit de projectlocatie. Elk collectief ontwikkelt een kunstproject rondom een specifieke 'moving (hi)story' en onderzoekt zo hoe een Artisteducator van betekenis kan zijn in de wijk.",
        has imagePath "default.png",
        has location "'t Arnhemse Broek, Arnhem",
        has createdAt 2024-09-01T09:00:00+0000,
        has startDate 2024-09-09T00:00:00+0000,
        has endDate 2025-06-27T23:59:00+0000,
        has isPublic true;

    $p_artez_animal isa project,
        has id "cc030002-1111-4111-8111-000000030002",
        has name "Animal Voices - Burgers' Zoo",
        has description "De opleiding Artisteducator in Theater werkt samen met Burgers' Zoo. Het onderzoek gaat over de verhouding tussen mens en dier en hoe studenten de 'stem' van dieren kunnen representeren in hun theaterwerk - in een complexe omgeving waarin educatie, dierenwelzijn en machtsverhoudingen samenkomen.",
        has imagePath "default.png",
        has location "Burgers' Zoo, Antoon van Hooffplein 1, Arnhem",
