    # Project 1: Foto van de Wijk Klarendal
    $p_kl1 isa project,
        has id "37f8e1a7-4cbd-4e1a-b980-19adaeb36176",
        has name "Foto van de Wijk Klarendal",
        has description "Studenten maken een 'foto van de wijk' — een visueel en kwalitatief onderzoek naar de situatie in Klarendal door de ogen van studenten. Met visual appraisal methoden brengen zij de leefomgeving, sociale cohesie en gezondheid in kaart.",
        has imagePath "project_monitoring.png",
        has createdAt 2024-09-15T09:00:00+0000,
        has startDate 2024-10-01T00:00:00+0000,
        has endDate 2025-02-28T23:59:00+0000,
        has isPublic true;

