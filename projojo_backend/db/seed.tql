        has description "Onderzoek naar hoe wijkprofessionals en bewoners in Klarendal omgaan met verward gedrag. Studenten van de HAN minor Overheid, Bestuur en Beleid voeren kwalitatief onderzoek uit en komen met beleidsaanbevelingen.",
        has imagePath "project_sustainability.png",
        has createdAt 2024-09-20T10:00:00+0000,
        has startDate 2024-10-15T00:00:00+0000,
